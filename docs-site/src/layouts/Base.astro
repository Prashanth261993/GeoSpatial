---
import "../styles/global.css";
const { title = "Building a Real-Time Geospatial Platform", description = "A Staff-level engineering journey: tracking, indexing, and matching thousands of moving entities in real time." } = Astro.props;
const base = import.meta.env.BASE_URL;

// Phases that have a written chapter on this page. Add an entry when a new
// phase ships — the nav dropdown renders itself from this list.
const phases = [
  { n: 1, t: "Ingest + live map" },
  { n: 2, t: "H3 indexing" },
  { n: 3, t: "Matching engine" },
  { n: 4, t: "Redpanda backbone" },
  { n: 5, t: "Surge analytics" },
  { n: 6, t: "Real-feed toggle" },
  { n: 7, t: "Cinematic frontend" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${base}/img/phase1/hero.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="bg-fx" aria-hidden="true"></div>

    <nav class="top">
      <div class="wrap">
        <a class="brand" href={base}><span class="dot"></span> Geospatial Platform</a>
        <div class="links">
          <a href="#roadmap">Roadmap</a>
          <details class="menu">
            <summary>Phases <span class="caret">▾</span></summary>
            <div class="panel">
              {phases.map((p) => (
                <a href={`#phase-${p.n}`}><span class="pn">{String(p.n).padStart(2, "0")}</span>{p.t}</a>
              ))}
            </div>
          </details>
          <a href="https://github.com/Prashanth261993/GeoSpatial">GitHub</a>
        </div>
      </div>
    </nav>

    <slot />

    <!-- Lightbox: click any figure image to zoom -->
    <div id="lightbox" class="lb" aria-hidden="true">
      <button class="lb-close" aria-label="Close (Esc)">✕</button>
      <div class="lb-hint">scroll / pinch to zoom · drag to pan · Esc to close</div>
      <div class="lb-stage"><img id="lb-img" alt="" /></div>
    </div>

    <footer>
      <div class="wrap">
        <div>Built in the open — one vertical slice per phase. © 2026</div>
        <div><a href="https://github.com/Prashanth261993/GeoSpatial">Prashanth261993/GeoSpatial</a></div>
      </div>
    </footer>

    <!-- Mermaid: dark themed diagrams -->
    <script is:inline type="module">
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
      mermaid.initialize({
        startOnLoad: true,
        theme: "base",
        themeVariables: {
          background: "#0d1119",
          primaryColor: "#10151f",
          primaryBorderColor: "#2a3346",
          primaryTextColor: "#cdd6f4",
          lineColor: "#89dceb",
          fontFamily: "ui-monospace, monospace",
          fontSize: "14px",
        },
      });
    </script>

    <!-- Scroll reveal -->
    <script is:inline>
      const io = new IntersectionObserver((es) => {
        es.forEach((e) => { if (e.isIntersecting) e.target.classList.add("in"); });
      }, { threshold: 0.12 });
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>

    <!-- Nav dropdown: close on outside-click, link-click, Esc -->
    <script is:inline>
      (() => {
        const menu = document.querySelector("nav.top .menu");
        if (!menu) return;
        document.addEventListener("click", (e) => {
          if (menu.open && !menu.contains(e.target)) menu.open = false;
        });
        menu.querySelectorAll(".panel a").forEach((a) =>
          a.addEventListener("click", () => { menu.open = false; })
        );
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && menu.open) menu.open = false;
        });
      })();
    </script>

    <!-- Lightbox interactions: open, zoom (wheel/pinch), pan (drag), close -->
    <script is:inline>
      (() => {
        const lb = document.getElementById("lightbox");
        const img = document.getElementById("lb-img");
        const close = lb.querySelector(".lb-close");
        let scale = 1, tx = 0, ty = 0, dragging = false, sx = 0, sy = 0;

        const apply = () => { img.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`; };
        const reset = () => { scale = 1; tx = 0; ty = 0; apply(); };

        const open = (src, alt) => {
          img.src = src; img.alt = alt || "";
          reset();
          lb.classList.add("open"); lb.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
        };
        const hide = () => {
          lb.classList.remove("open"); lb.setAttribute("aria-hidden", "true");
          document.body.style.overflow = "";
          img.src = "";
        };

        // Open from any figure image
        document.querySelectorAll(".figure img").forEach((el) => {
          el.style.cursor = "zoom-in";
          el.addEventListener("click", () => open(el.currentSrc || el.src, el.alt));
        });

        close.addEventListener("click", hide);
        lb.addEventListener("click", (e) => { if (e.target === lb || e.target.classList.contains("lb-stage")) hide(); });
        document.addEventListener("keydown", (e) => {
          if (!lb.classList.contains("open")) return;
          if (e.key === "Escape") hide();
          if (e.key === "0") reset();
        });

        // Wheel zoom toward cursor
        lb.addEventListener("wheel", (e) => {
          if (!lb.classList.contains("open")) return;
          e.preventDefault();
          const prev = scale;
          scale = Math.min(8, Math.max(1, scale * (e.deltaY < 0 ? 1.15 : 1 / 1.15)));
          if (scale === 1) { tx = 0; ty = 0; }
          else {
            const f = scale / prev;
            tx = tx * f; ty = ty * f;
          }
          apply();
        }, { passive: false });

        // Double-click toggles 1x / 2.5x
        img.addEventListener("dblclick", (e) => {
          e.stopPropagation();
          scale = scale > 1 ? 1 : 2.5;
          if (scale === 1) { tx = 0; ty = 0; }
          apply();
        });

        // Drag to pan when zoomed
        img.addEventListener("pointerdown", (e) => {
          if (scale === 1) return;
          dragging = true; sx = e.clientX - tx; sy = e.clientY - ty;
          img.setPointerCapture(e.pointerId); img.style.cursor = "grabbing";
        });
        img.addEventListener("pointermove", (e) => {
          if (!dragging) return;
          tx = e.clientX - sx; ty = e.clientY - sy; apply();
        });
        const endDrag = () => { dragging = false; img.style.cursor = scale > 1 ? "grab" : "zoom-out"; };
        img.addEventListener("pointerup", endDrag);
        img.addEventListener("pointercancel", endDrag);
      })();
    </script>
  </body>
</html>
