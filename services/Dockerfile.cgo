# Dockerfile for cgo services (e.g. indexer uses uber/h3-go, which links a C lib).
FROM golang:1.25-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY internal ./internal
COPY services ./services
ARG SVC
RUN CGO_ENABLED=1 go build -o /app ./services/${SVC}

# base-debian12 ships glibc (h3-go's C is statically linked into the binary,
# but the binary still dynamically links libc).
FROM gcr.io/distroless/base-debian12
COPY --from=build /app /app
ENTRYPOINT ["/app"]
