# Copy to .env and adjust. Never commit .env.

# --- Redpanda (Kafka API) ---
REDPANDA_BROKERS=localhost:19092

# --- Redis (live geo index + pub/sub) ---
REDIS_ADDR=localhost:6379

# --- TimescaleDB / Postgres (history) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=geo
POSTGRES_USER=geo
POSTGRES_PASSWORD=geo_dev_pw

# --- Region (Phase 0 default: Seattle) ---
REGION=seattle
MAP_CENTER_LAT=47.6062
MAP_CENTER_LNG=-122.3321

# --- OSRM (road-snapped movement, Phase 1) ---
OSRM_URL=http://localhost:5000

# --- Real-feed toggle (Phase 6) ---
# Feeds are OFF by default and toggled on-demand from the UI (conserves rate limits).
OPENSKY_ENABLED=false
# Optional OpenSky credentials (anonymous works but is rate-limited). Free signup at
# https://opensky-network.org/ raises limits.
OPENSKY_USER=
OPENSKY_PASS=
GTFS_RT_ENABLED=false

# --- Phase 1: simulator + frontend ---
DRIVERS=200
VITE_WS_URL=ws://localhost:8090/ws
# Optional free key for dark vector tiles; falls back to demotiles if empty.
VITE_MAPTILER_KEY=
